APP_NAME=VenueSync
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

# XAMPP MySQL settings (default XAMPP has no password)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=venuesync
DB_USERNAME=root
DB_PASSWORD=

JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

STRIPE_KEY=pk_test_YOUR_KEY
STRIPE_SECRET=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@venuesync.pk"
MAIL_FROM_NAME="VenueSync"

FILESYSTEM_DISK=public
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
